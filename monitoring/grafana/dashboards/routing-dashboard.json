{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "routing_sim_total_requests",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      }
    },
    {
      "title": "Average Latency (ms)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "routing_sim_avg_latency_ms",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 500,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "orange", "value": 200 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      }
    },
    {
      "title": "P95 Latency (ms)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "routing_sim_p95_latency_ms",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "routing_sim_cache_hit_ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "title": "Latency Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "routing_sim_avg_latency_ms",
          "legendFormat": "Avg Latency",
          "refId": "A"
        },
        {
          "expr": "routing_sim_p95_latency_ms",
          "legendFormat": "P95 Latency",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "routing_sim_rps",
          "legendFormat": "Requests/sec",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "routing_sim_total_cost_usd",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    }
  ],
  "schemaVersion": 39,
  "title": "Cloud Routing Simulator",
  "uid": "routing-sim-dash",
  "version": 1
}
